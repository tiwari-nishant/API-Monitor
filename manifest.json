{
  "manifest_version": 2,
  "name": "OpenBMC GUI Monitor",
  "version": "1.0.0",
  "description": "Monitor and capture OpenBMC Redfish API calls with export functionality for REST and WebSocket connections",
  "author": "Your Name",
  
  "permissions": [
    "webRequest",
    "webRequestBlocking",
    "storage",
    "tabs",
    "downloads",
    "<all_urls>"
  ],
  
  "background": {
    "scripts": [
      "utils/request-parser.js",
      "background/storage-manager.js",
      "background/request-interceptor.js",
      "background/background.js"
    ],
    "persistent": true
  },
  
  "sidebar_action": {
    "default_title": "OpenBMC GUI Monitor",
    "default_panel": "sidebar/sidebar.html",
    "default_icon": {
      "16": "icons/icon-16.png",
      "48": "icons/icon-48.png"
    }
  },
  
  "browser_action": {
    "default_icon": {
      "16": "icons/icon-16.png",
      "48": "icons/icon-48.png",
      "96": "icons/icon-96.png"
    },
    "default_title": "Open OpenBMC Monitor Sidebar"
  },
  
  "icons": {
    "16": "icons/icon-16.png",
    "48": "icons/icon-48.png",
    "96": "icons/icon-96.png"
  }
}